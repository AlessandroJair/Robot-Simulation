<?xml version="1.0"?>
<launch>
  <!-- Robot -->
  <include file="$(find differential)/launch/lcmine_husky_world.launch"/>

  <arg name="use_sim_time" default="true"/>
  <param name="use_sim_time" value="$(arg use_sim_time)"/>

  <group ns="rtabmap">

  <!-- ICP ODOMETRY -->
  <node pkg="rtabmap_odom" type="icp_odometry" name="icp_odometry" output="screen">
    <remap from="scan_cloud" to="/velodyne_points"/>
    <remap from="imu" to="/imu/data"/>

    <param name="frame_id" type="string" value="husky/base_link"/>
    <param name="odom_frame_id" type="string" value="odom"/>
    <param name="publish_tf" type="bool" value="true"/>
    <param name="wait_for_transform" type="bool" value="true"/>
    <param name="wait_for_transform_duration" type="double" value="0.5"/>

    <!-- IMU CONFIGURATION -->
    <param name="Imu/Enable" type="string" value="true"/>
    <param name="wait_imu_to_init" type="bool" value="true"/>

    <!-- SCAN DESKEWING desactivado: el plugin de Velodyne en Gazebo no genera
         timestamps por punto, todos tienen el mismo stamp y deskewing falla -->
    <param name="deskewing" type="bool" value="false"/>

    <!-- GROUND CONSTRAINT -->
    <param name="Odom/AlignWithGround" type="bool" value="true"/>

    <!-- ICP parameters -->
    <param name="Icp/VoxelSize" type="string" value="0.1"/>
    <param name="Icp/PointToPlaneK" type="string" value="20"/>
    <param name="Icp/PointToPlane" type="string" value="true"/>
    <param name="Icp/Iterations" type="string" value="30"/>
    <param name="Icp/Epsilon" type="string" value="0.0001"/>
    <param name="Icp/MaxTranslation" type="string" value="2.0"/>
    <param name="Icp/MaxCorrespondenceDistance" type="string" value="1.0"/>
    <param name="Icp/PM" type="string" value="true"/>
    <param name="Icp/PMOutlierRatio" type="string" value="0.85"/>

    <!-- Odometry Strategy -->
    <param name="Odom/Strategy" type="string" value="0"/>
    <param name="Odom/ScanKeyFrameThr" type="string" value="0.9"/>
    <param name="Odom/ResetCountdown" type="string" value="0"/>

    <!-- Frame to Map -->
    <param name="OdomF2M/ScanSubtractRadius" type="string" value="0.1"/>
    <param name="OdomF2M/ScanMaxSize" type="string" value="15000"/>
    <param name="OdomF2M/BundleAdjustment" type="string" value="1"/>
  </node>

  <!-- RTAB-MAP -->
  <node name="rtabmap" pkg="rtabmap_slam" type="rtabmap" output="screen" args="--delete_db_on_start">

    <param name="frame_id" type="string" value="husky/base_link"/>
    <param name="odom_frame_id" type="string" value="odom"/>
    <param name="subscribe_depth" type="bool" value="false"/>
    <param name="subscribe_rgb" type="bool" value="true"/>
    <param name="subscribe_scan_cloud" type="bool" value="true"/>
    <param name="approx_sync" type="bool" value="true"/>
    <param name="queue_size" type="int" value="10"/>

    <remap from="rgb/image" to="/camera/image_raw"/>
    <remap from="rgb/camera_info" to="/camera/camera_info"/>
    <remap from="scan_cloud" to="/velodyne_points"/>
    <remap from="imu" to="/imu/data"/>

    <!-- Database -->
    <param name="database_path" type="string" value="~/.ros/rtabmap_3d.db"/>

    <!-- TF Publishing -->
    <param name="publish_tf" type="bool" value="true"/>
    <param name="map_always_update" type="bool" value="true"/>
    <param name="map_empty_ray_tracing" type="bool" value="true"/>

    <!-- IMU -->
    <param name="Imu/Enable" type="string" value="true"/>

    <!-- Deteccion y memoria -->
    <param name="Rtabmap/DetectionRate" type="string" value="1.0"/>
    <param name="Rtabmap/TimeThr" type="string" value="0"/>
    <param name="Mem/IncrementalMemory" type="string" value="true"/>
    <param name="Mem/InitWMWithAllNodes" type="string" value="false"/>

    <!-- 3D Mapping -->
    <param name="Grid/3D" type="string" value="true"/>
    <param name="Grid/FromDepth" type="string" value="false"/>
    <param name="Grid/RayTracing" type="string" value="true"/>
    <param name="Grid/CellSize" type="string" value="0.05"/>
    <param name="Grid/ClusterRadius" type="string" value="1"/>
    <param name="Grid/GroundIsObstacle" type="string" value="false"/>
    <param name="Grid/MaxObstacleHeight" type="string" value="2.0"/>
    <param name="Grid/MaxGroundHeight" type="string" value="0.0"/>
    <param name="Grid/NormalK" type="string" value="20"/>
    <param name="Grid/RangeMax" type="string" value="50.0"/>
    <param name="Grid/RangeMin" type="string" value="1.0"/>
    <param name="GridGlobal/MinSize" type="string" value="20"/>
    <param name="GridGlobal/Eroded" type="string" value="false"/>

    <!-- ICP for loop closure -->
    <param name="Reg/Strategy" type="string" value="1"/>
    <param name="Icp/VoxelSize" type="string" value="0.1"/>
    <param name="Icp/PointToPlaneK" type="string" value="20"/>
    <param name="Icp/PointToPlane" type="string" value="true"/>
    <param name="Icp/Iterations" type="string" value="30"/>
    <param name="Icp/Epsilon" type="string" value="0.001"/>
    <param name="Icp/MaxTranslation" type="string" value="3"/>
    <param name="Icp/MaxCorrespondenceDistance" type="string" value="1.0"/>
    <param name="Icp/PM" type="string" value="true"/>
    <param name="Icp/PMOutlierRatio" type="string" value="0.7"/>

    <!-- Visual features -->
    <param name="Kp/MaxFeatures" type="string" value="400"/>
    <param name="Kp/DetectorStrategy" type="string" value="6"/>
    <param name="GFTT/MinDistance" type="string" value="10"/>

    <!-- Loop closure -->
    <param name="Mem/NotLinkedNodesKept" type="string" value="false"/>
    <param name="Mem/STMSize" type="string" value="30"/>
    <param name="Rtabmap/LoopRatio" type="string" value="0.7"/>

    <!-- Proximity and loop closure detection -->
    <param name="RGBD/ProximityMaxGraphDepth" type="string" value="50"/>
    <param name="RGBD/ProximityPathMaxNeighbors" type="string" value="10"/>
    <param name="RGBD/AngularUpdate" type="string" value="0.015"/>
    <param name="RGBD/LinearUpdate" type="string" value="0.01"/>
    <param name="RGBD/CreateOccupancyGrid" type="string" value="true"/>
    <param name="Optimizer/Strategy" type="string" value="1"/>
  </node>
  </group>

</launch>
