<?xml version="1.0"?>
<launch>

  <!-- Argumentos -->
  <arg name="config_file" default="$(find differential)/config/waypoints_config.yaml"/>
  <arg name="use_rviz" default="true"/>
  <arg name="use_move_base" default="true"/>

  <!-- move_base (condicional) -->
  <include file="$(find differential)/launch/move_base.launch" if="$(arg use_move_base)"/>

  <!-- Nodo de navegacion por waypoints -->
  <node pkg="differential" type="waypoint_navigator_yaml.py" name="waypoint_navigator" output="screen">
    <param name="config_file" value="$(arg config_file)"/>
    <param name="use_move_base" value="$(arg use_move_base)"/>
  </node>

  <!-- Metrics logger -->
  <include file="$(find robot_metrics)/launch/metrics_logger.launch">
    <arg name="robot_name" value="differential"/>
    <arg name="model_name" value="husky"/>
    <arg name="cmd_vel_topic" value="/cmd_vel"/>
  </include>

  <!-- RViz para visualizacion (opcional) -->
  <group if="$(arg use_rviz)">
    <node pkg="rviz" type="rviz" name="waypoint_rviz" args="-d $(find differential)/rviz/waypoint_navigation.rviz"/>
  </group>

</launch>
