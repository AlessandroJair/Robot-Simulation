<launch>

    <!-- these are the arguments you can pass this launch file, for example paused:=true -->
    <arg name="paused" default="true" />
    <arg name="use_sim_time" default="true" />
    <arg name="gui" default="true" />
    <arg name="headless" default="false" />
    <arg name="debug" default="false" />

    <!-- We resume the logic in empty_world.launch, changing only the name of the world to be launched -->
    <include file="$(find gazebo_ros)/launch/empty_world.launch">
        <arg name="world_name" value="$(find rocker_bogie)/world/mine/lcmine.world" />
        <arg name="debug" value="$(arg debug)" />
        <arg name="gui" value="$(arg gui)" />
        <arg name="paused" value="$(arg paused)" />
        <arg name="use_sim_time" value="$(arg use_sim_time)" />
        <arg name="headless" value="$(arg headless)" />
    </include>

    <!-- Load the URDF into the ROS Parameter Server (global, fuera del namespace) -->
    <param name="rocker_bogie/robot_description" command="xacro --inorder '$(find rocker_bogie)/urdf/ensamblajeurdf.xacro'" />

    <!-- Spawn the robot in Gazebo from the URDF -->
    <node name="spawn_rocker_bogie" pkg="gazebo_ros" type="spawn_model"
          args="-param rocker_bogie/robot_description -urdf -model rocker_bogie -x 33.5 -y 0.2 -z 1.3 -Y 3.14159"
          output="screen" />

    <group ns="rocker_bogie">

        <!-- Velocity controllers for 6 wheels -->
        <rosparam>
            joint_state_controller:
                type: joint_state_controller/JointStateController
                publish_rate: 50

            wheel_vel_controller_fr:
                type: velocity_controllers/JointVelocityController
                joint: rev_9
            wheel_vel_controller_mr:
                type: velocity_controllers/JointVelocityController
                joint: rev_10
            wheel_vel_controller_rr:
                type: velocity_controllers/JointVelocityController
                joint: rev_11
            wheel_vel_controller_fl:
                type: velocity_controllers/JointVelocityController
                joint: rev_14
            wheel_vel_controller_ml:
                type: velocity_controllers/JointVelocityController
                joint: rev_13
            wheel_vel_controller_rl:
                type: velocity_controllers/JointVelocityController
                joint: rev_12

            gazebo_ros_control:
                pid_gains:
                    rev_9:  {p: 26.0, i: 1.0, d: 0.0}
                    rev_10: {p: 26.0, i: 1.0, d: 0.0}
                    rev_11: {p: 26.0, i: 1.0, d: 0.0}
                    rev_12: {p: 26.0, i: 1.0, d: 0.0}
                    rev_13: {p: 26.0, i: 1.0, d: 0.0}
                    rev_14: {p: 26.0, i: 1.0, d: 0.0}
                    differential_joint: {p: 1.0, i: 0.0, d: 0.0}
                    rocker_joint_r:     {p: 1.0, i: 0.0, d: 0.0}
                    rocker_joint_l:     {p: 1.0, i: 0.0, d: 0.0}
                    rev_3:              {p: 1.0, i: 0.0, d: 0.0}
                    rev_4:              {p: 1.0, i: 0.0, d: 0.0}
        </rosparam>

        <!-- Load and start controllers -->
        <node name="controller_starter" pkg="controller_manager" type="controller_manager"
              args="spawn joint_state_controller wheel_vel_controller_fl wheel_vel_controller_ml wheel_vel_controller_rl wheel_vel_controller_fr wheel_vel_controller_mr wheel_vel_controller_rr"
              output="screen" />

        <!-- Twist to individual wheel velocities -->
        <node name="twist_to_wheels" pkg="rocker_bogie" type="twist_to_wheels.py" output="screen">
            <param name="wheel_separation" value="0.6775" />
            <param name="wheel_radius" value="0.178" />
        </node>

        <!-- convert joint states to TF transforms for rviz, etc -->
        <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" output="screen">
            <param name="tf_prefix" value="rocker_bogie" />
            <remap from="robot_description" to="/rocker_bogie/robot_description" />
        </node>

    </group>

    <!-- Static TF: base_link_nav es base_link rotado 180° (nuevo frente del robot) -->
    <node pkg="tf" type="static_transform_publisher" name="base_link_nav_tf"
          args="0 0 0 3.14159 0 0 rocker_bogie/base_link_nav rocker_bogie/base_link 50" />

</launch>
