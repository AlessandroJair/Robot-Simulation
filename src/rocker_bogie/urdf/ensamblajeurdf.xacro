<!-- ================= DIFFERENTIAL BAR (connects to base_link) ================= -->
<!-- Differential pivot: AcopleTuboRB_1_1 pivots on base_link around Y axis -->
<joint name="differential_joint" type="revolute">
  <origin xyz="0.283305 0.285198 0.576664" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="AcopleTuboRB_1_1"/>
  <axis xyz="0.0 1.0 0.0"/>
  <limit lower="-0.15" upper="0.15" effort="100" velocity="0.5"/>
  <dynamics damping="80.0" friction="6.0"/>
</joint>

